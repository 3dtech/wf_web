{
	"name": "wf-svelte",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build --base=#BASE#",
		"build-wordpress": "WF_PACKAGE=wordpress vite build --base=#BASE#",
		"build-full": "WF_PACKAGE=full vite build --base=#BASE#",
		"build-kliinikum": "WF_PACKAGE=kliinikum-wordpress vite build --base=#BASE#",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"autoprefixer": "^10.4.20",
		"postcss": "^8.4.47",
		"svelte": "^4.2.7",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.14",
		"typescript": "^5.0.0",
		"vite": "^5.0.3",
		"vite-plugin-singlefile": "^2.0.2"
	},
	"type": "module",
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.5"
	}
}
